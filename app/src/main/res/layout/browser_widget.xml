<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_vertical">

    <!-- Search Section -->
    <TextView
        android:id="@+id/search_placeholder_text"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/widget_search_bg"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:drawableStart="@drawable/ic_widget_search"
        android:drawablePadding="10dp"
        android:drawableTint="#B3FFFFFF"
        android:text="Arama yapın veya URL girin..."
        android:textColor="#B3FFFFFF"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:focusable="true"
        android:clickable="true" />

    <!-- Button Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp"
        android:weightSum="4">

        <!-- Button 1: New Tab -->
        <LinearLayout
            android:id="@+id/btn_new_tab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:focusable="true"
            android:clickable="true">
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/widget_circle_bg">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_widget_new_tab"
                    android:tint="#FFFFFFFF"
                    android:contentDescription="New Tab" />
            </FrameLayout>
            <TextView
                android:id="@+id/btn_new_tab_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Yeni Sekme"
                android:textColor="#FFFFFFFF"
                android:textSize="10sp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Button 2: Incognito -->
        <LinearLayout
            android:id="@+id/btn_incognito"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:focusable="true"
            android:clickable="true">
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/widget_circle_bg">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_widget_incognito"
                    android:tint="#FFFFFFFF"
                    android:contentDescription="Incognito" />
            </FrameLayout>
            <TextView
                android:id="@+id/btn_incognito_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Gizli Mod"
                android:textColor="#FFFFFFFF"
                android:textSize="10sp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Button 3: Bookmarks -->
        <LinearLayout
            android:id="@+id/btn_bookmarks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:focusable="true"
            android:clickable="true">
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/widget_circle_bg">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_widget_bookmark"
                    android:tint="#FFFFFFFF"
                    android:contentDescription="Bookmarks" />
            </FrameLayout>
            <TextView
                android:id="@+id/btn_bookmarks_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Yer İmleri"
                android:textColor="#FFFFFFFF"
                android:textSize="10sp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Button 4: History -->
        <LinearLayout
            android:id="@+id/btn_history"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:focusable="true"
            android:clickable="true">
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/widget_circle_bg">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_widget_history"
                    android:tint="#FFFFFFFF"
                    android:contentDescription="History" />
            </FrameLayout>
            <TextView
                android:id="@+id/btn_history_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Geçmiş"
                android:textColor="#FFFFFFFF"
                android:textSize="10sp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
